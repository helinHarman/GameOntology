<?xml version="1.0"?>
<rdf:RDF xmlns="http://www.semanticweb.org/taner/ontologies/2026/3/gameOntology/"
     xml:base="http://www.semanticweb.org/taner/ontologies/2026/3/gameOntology/"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:gameOntology="http://www.semanticweb.org/taner/ontologies/2026/3/gameOntology#">
    <owl:Ontology rdf:about="http://www.semanticweb.org/taner/ontologies/2026/3/gameOntology"/>

    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/taner/ontologies/2026/3/gameOntology#belongsTo">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/taner/ontologies/2026/3/gameOntology#hasCharacter"/>
    </owl:ObjectProperty>


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/taner/ontologies/2026/3/gameOntology#completesQuest">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
    </owl:ObjectProperty>
    

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/taner/ontologies/2026/3/gameOntology#earnsAchievement">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
    </owl:ObjectProperty>


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/taner/ontologies/2026/3/gameOntology#equippedWith">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
    </owl:ObjectProperty>
    

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/taner/ontologies/2026/3/gameOntology#givesReward">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
    </owl:ObjectProperty>
    


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/taner/ontologies/2026/3/gameOntology#hasCharacter">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
    </owl:ObjectProperty>


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/taner/ontologies/2026/3/gameOntology#hasItem">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
    </owl:ObjectProperty>
    


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/taner/ontologies/2026/3/gameOntology#hasQuest">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
    </owl:ObjectProperty>
    


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/taner/ontologies/2026/3/gameOntology#plays">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
    </owl:ObjectProperty>
    



    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/taner/ontologies/2026/3/gameOntology#useItem">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
    </owl:ObjectProperty>


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/taner/ontologies/2026/3/gameOntology#wears">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/taner/ontologies/2026/3/gameOntology#hasDamage">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
    </owl:DatatypeProperty>


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/taner/ontologies/2026/3/gameOntology#hasDifficulty">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
