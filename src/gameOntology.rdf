    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/taner/ontologies/2026/3/gameOntology#hasLevel">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
