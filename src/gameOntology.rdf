    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    




    <owl:Class rdf:about="http://www.semanticweb.org/taner/ontologies/2026/3/gameOntology#Achievement"/>
    



    <owl:Class rdf:about="http://www.semanticweb.org/taner/ontologies/2026/3/gameOntology#Armor">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/taner/ontologies/2026/3/gameOntology#Item"/>
    </owl:Class>
    




    <owl:Class rdf:about="http://www.semanticweb.org/taner/ontologies/2026/3/gameOntology#Character">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/taner/ontologies/2026/3/gameOntology#belongsTo"/>
                <owl:someValuesFrom rdf:resource="http://www.semanticweb.org/taner/ontologies/2026/3/gameOntology#Player"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/taner/ontologies/2026/3/gameOntology#equippedWith"/>
                <owl:someValuesFrom rdf:resource="http://www.semanticweb.org/taner/ontologies/2026/3/gameOntology#Weapon"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/taner/ontologies/2026/3/gameOntology#useItem"/>
                <owl:someValuesFrom rdf:resource="http://www.semanticweb.org/taner/ontologies/2026/3/gameOntology#Item"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/taner/ontologies/2026/3/gameOntology#wears"/>
                <owl:someValuesFrom rdf:resource="http://www.semanticweb.org/taner/ontologies/2026/3/gameOntology#Armor"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/taner/ontologies/2026/3/gameOntology#hasLevel"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#rational"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>


    <owl:Class rdf:about="http://www.semanticweb.org/taner/ontologies/2026/3/gameOntology#Game">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/taner/ontologies/2026/3/gameOntology#hasItem"/>
                <owl:someValuesFrom rdf:resource="http://www.semanticweb.org/taner/ontologies/2026/3/gameOntology#Item"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/taner/ontologies/2026/3/gameOntology#hasQuest"/>
                <owl:someValuesFrom rdf:resource="http://www.semanticweb.org/taner/ontologies/2026/3/gameOntology#Quest"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/taner/ontologies/2026/3/gameOntology#hasName"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#rational"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    


    <owl:Class rdf:about="http://www.semanticweb.org/taner/ontologies/2026/3/gameOntology#Item">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/taner/ontologies/2026/3/gameOntology#hasDamage"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#rational"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    



    <owl:Class rdf:about="http://www.semanticweb.org/taner/ontologies/2026/3/gameOntology#Player">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/taner/ontologies/2026/3/gameOntology#completesQuest"/>
                <owl:someValuesFrom rdf:resource="http://www.semanticweb.org/taner/ontologies/2026/3/gameOntology#Quest"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/taner/ontologies/2026/3/gameOntology#earnsAchievement"/>
                <owl:someValuesFrom rdf:resource="http://www.semanticweb.org/taner/ontologies/2026/3/gameOntology#Achievement"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/taner/ontologies/2026/3/gameOntology#hasCharacter"/>
                <owl:someValuesFrom rdf:resource="http://www.semanticweb.org/taner/ontologies/2026/3/gameOntology#Character"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/taner/ontologies/2026/3/gameOntology#plays"/>
                <owl:someValuesFrom rdf:resource="http://www.semanticweb.org/taner/ontologies/2026/3/gameOntology#Game"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/taner/ontologies/2026/3/gameOntology#hasUsername"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#rational"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    



    <owl:Class rdf:about="http://www.semanticweb.org/taner/ontologies/2026/3/gameOntology#Quest">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/taner/ontologies/2026/3/gameOntology#givesReward"/>
                <owl:someValuesFrom rdf:resource="http://www.semanticweb.org/taner/ontologies/2026/3/gameOntology#Item"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/taner/ontologies/2026/3/gameOntology#hasDifficulty"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#rational"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    


    <owl:Class rdf:about="http://www.semanticweb.org/taner/ontologies/2026/3/gameOntology#Weapon">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/taner/ontologies/2026/3/gameOntology#Item"/>
    </owl:Class>
    


